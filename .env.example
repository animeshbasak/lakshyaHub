# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Site URL (set to your Vercel domain in production) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Force a default currency for /pricing when running locally (no Vercel geo headers).
# Vercel/Cloudflare geo headers override this. Values: USD | INR
NEXT_PUBLIC_DEFAULT_CURRENCY=

# ─── AI Providers (server-side only) ─────────────────────────────────────────
# /api/ai/evaluate uses these in priority order: GROQ -> GEMINI -> ANTHROPIC.
# At least one MUST be set or evaluations return 503 'provider_unconfigured'.
#
# Free tier (recommended): https://console.groq.com/keys (no card)
GROQ_API_KEY=gsk_...
# Free tier 60 RPM: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Paid / BYOK only: https://console.anthropic.com/settings/keys ($0.12/eval)
ANTHROPIC_API_KEY=sk-ant-...

# Older naming retained for backwards-compat with existing scrapers + AI router:
AI_PROVIDER_GEMINI_API_KEY=AIza...
AI_PROVIDER_GROQ_API_KEY=gsk_...
AI_PROVIDER_OPENROUTER_API_KEY=

# ─── AI Router Config ─────────────────────────────────────────────────────────
AI_PROVIDER_PRIMARY=gemini
AI_PROVIDER_FALLBACK=anthropic
AI_PROVIDER_GEMINI_ENABLED=true
AI_PROVIDER_GROQ_ENABLED=true
AI_PROVIDER_OPENROUTER_ENABLED=false

# ─── Apify (job scraping) ─────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...

# ─── Careerops integration ────────────────────────────────────────────────────
CAREEROPS_PROMPT_VERSION=1.0.0

# ─── BYOK encryption (Phase 4 / S4) ───────────────────────────────────────────
# 32-byte base64 key — generate: openssl rand -base64 32. Server-only.
BYOK_MASTER_KEY=

# ─── Rate limiting + queue (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Cron + internal endpoints ────────────────────────────────────────────────
# Random hex >= 32 chars — generate: openssl rand -hex 32
CRON_SECRET=
HEALTH_SECRET=

# ─── Stripe (Phase 4 billing) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Observability (S10) ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Cost guards (S4) ─────────────────────────────────────────────────────────
LLM_HOURLY_CEILING_USD=50

# ─── Supabase service role (server-only, NEVER expose to client) ──────────────
SUPABASE_SERVICE_ROLE_KEY=
