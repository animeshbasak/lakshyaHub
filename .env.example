# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Site URL (set to your Vercel domain in production) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Force a default currency for /pricing when running locally (no Vercel geo headers).
# Vercel/Cloudflare geo headers override this. Values: USD | INR
NEXT_PUBLIC_DEFAULT_CURRENCY=

# ─── AI Providers (server-side only) ─────────────────────────────────────────
# /api/ai/evaluate uses these in priority order: GROQ -> GEMINI -> ANTHROPIC.
# At least one MUST be set or evaluations return 503 'provider_unconfigured'.
#
# Free tier (recommended): https://console.groq.com/keys (no card)
GROQ_API_KEY=gsk_...
# Free tier 60 RPM: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Paid / BYOK only: https://console.anthropic.com/settings/keys ($0.12/eval)
ANTHROPIC_API_KEY=sk-ant-...

# Older naming retained for backwards-compat with existing scrapers + AI router:
AI_PROVIDER_GEMINI_API_KEY=AIza...
AI_PROVIDER_GROQ_API_KEY=gsk_...
AI_PROVIDER_OPENROUTER_API_KEY=

# ─── AI Router Config ─────────────────────────────────────────────────────────
AI_PROVIDER_PRIMARY=gemini
AI_PROVIDER_FALLBACK=anthropic
AI_PROVIDER_GEMINI_ENABLED=true
AI_PROVIDER_GROQ_ENABLED=true
AI_PROVIDER_OPENROUTER_ENABLED=false

# ─── Apify (job scraping) ─────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...

# ─── Careerops integration ────────────────────────────────────────────────────
CAREEROPS_PROMPT_VERSION=1.0.0

# ─── BYOK encryption (Phase 4 / S4) ───────────────────────────────────────────
# 32-byte base64 key — generate: openssl rand -base64 32. Server-only.
BYOK_MASTER_KEY=

# ─── Rate limiting + queue (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Cron + internal endpoints ────────────────────────────────────────────────
# Random hex >= 32 chars — generate: openssl rand -hex 32
CRON_SECRET=
HEALTH_SECRET=

# ─── Stripe (Phase 4 billing) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Observability (S10) ──────────────────────────────────────────────────────
# Sentry DSN — same value goes in both vars. Runtime: server uses SENTRY_DSN,
# browser uses NEXT_PUBLIC_SENTRY_DSN (NEXT_PUBLIC_ is shipped to client by
# Next.js convention). When unset, Sentry init is a no-op (zero overhead).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Source-map upload at build time. Get from Sentry: Settings → Auth Tokens →
# create one with `project:releases` + `org:read` scope. Build-time only;
# never read at runtime. When unset, builds still succeed but source maps
# are not uploaded (stack traces will show minified code).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Cost guards (S4) ─────────────────────────────────────────────────────────
LLM_HOURLY_CEILING_USD=50

# ─── Supabase service role (server-only, NEVER expose to client) ──────────────
SUPABASE_SERVICE_ROLE_KEY=

# ─── GTM hooks (eval result page) ─────────────────────────────────────────────
# Provider-agnostic Upgrade CTA. Lakshya geo-detects the user (IN vs rest)
# and renders the matching link. Use any hosted-checkout URL:
#   - India: Razorpay Payment Link (UPI + cards), Cashfree, Instamojo
#   - Global: Stripe Payment Link, Paddle, Lemon Squeezy
NEXT_PUBLIC_PAYMENT_LINK_IN=
NEXT_PUBLIC_PAYMENT_LINK_GLOBAL=

# Visibility threshold (0..5). Only show the CTA when eval score ≤ this.
# 5.0 (default) = always show. 4.0 = only on low-scoring evals.
NEXT_PUBLIC_UPGRADE_CTA_MAX_SCORE=5.0

# Beta-validation inbox — when no payment link is configured, the eval-page
# CTA shows a "I'd pay for this" mailto button pointing here. Set to
# whichever inbox you actually monitor. Defaults to the project owner's email.
NEXT_PUBLIC_BETA_INTEREST_EMAIL=

# Hide the CTA entirely (e.g. on /share/[id] for public eval views).
# Set to "1" to disable.
NEXT_PUBLIC_UPGRADE_CTA_DISABLE=

# DEPRECATED — back-compat fallback when both region links are unset.
# Prefer NEXT_PUBLIC_PAYMENT_LINK_IN / _GLOBAL above.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# NOTE: QStash vars are also defined above in the "Rate limiting + queue"
# section. The duplicate block here is intentional — kept inline with the
# nearby S4 cost-ceiling comment for runbook readability. Either set will
# resolve the same variables in process.env.

# ─── Email sender (Resend) ───────────────────────────────────────────────────
# Used by /api/scan/cadence-digest to email users their follow-up summary.
# When unset, the route returns 503 with a hint — no inline fallback (would
# spam ourselves with no auth provider).
#
# Resend free tier: 3,000 emails/month + 100/day. Get key at https://resend.com.
# RESEND_FROM_ADDRESS must be a domain you've verified on Resend (e.g.
# "Lakshya <hello@getlakshya.app>"). For testing without a verified domain,
# Resend allows from "onboarding@resend.dev".
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Daily evaluation cap per user (S4 cost ceiling). Returns 402 Payment Required
# when exceeded. Set per the LLM spend you're willing to absorb on free tier.
DAILY_EVAL_LIMIT_PER_USER=50
